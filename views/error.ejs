<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Error - Trading Journal</title>
    <link rel='stylesheet' href='/stylesheets/style.css' />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
</head>
<body>
    <header>
        <nav class="container">
            <h1>📈 TRADING JOURNAL</h1>
            <ul>
                <li><a href="/">Home</a></li>
                <li><a href="/login">Login</a></li>
            </ul>
        </nav>
    </header>

    <div class="container">
        <div class="main-content">
            <div style="max-width: 600px; margin: 60px auto; text-align: center;">
                <div class="alert alert-danger">
                    <h2 style="font-size: 48px; margin-bottom: 16px;">⚠️ ERROR</h2>
                    <p style="font-size: 16px; font-weight: 600; margin-bottom: 12px;"><%= message %></p>
                    <p style="color: var(--text-secondary); font-size: 14px;">Error Code: <%= error.status %></p>
                </div>

                <a href="/" style="color: var(--accent-green); text-decoration: none; font-weight: 600; display: inline-block; margin-top: 24px;">
                    <i class="fas fa-arrow-left"></i> Return Home
                </a>

                <% if (error.stack && process.env.NODE_ENV === 'development') { %>
                    <details style="margin-top: 40px; text-align: left; background: var(--bg-card); padding: 20px; border-radius: 10px; border: 1px solid var(--border);">
                        <summary style="cursor: pointer; color: var(--text-secondary); font-weight: 600;">Technical Details (Development)</summary>
                        <pre style="overflow-x: auto; margin-top: 16px; color: var(--text-muted); font-size: 12px;"><%= error.stack %></pre>
                    </details>
                <% } %>
            </div>
        </div>
    </div>

    <footer>
        <p>Need assistance? Check the logs or contact support</p>
    </footer>
</body>
</html>
