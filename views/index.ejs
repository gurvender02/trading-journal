<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Trading Journal - Elite Trader Dashboard</title>
    <link rel='stylesheet' href='/stylesheets/style.css' />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
</head>
<body>
    <header>
        <nav class="container">
            <h1>📈 TRADING JOURNAL</h1>
            <ul>
                <li><a href="/">Home</a></li>
                <li><a href="/login">Login</a></li>
                <li><a href="/register">Register</a></li>
            </ul>
        </nav>
    </header>

    <div class="container">
        <div class="main-content">
            <h2 style="text-align: center; margin-bottom: 16px;">ELITE TRADING DASHBOARD</h2>
            <p style="text-align: center; color: var(--text-secondary); margin-bottom: 40px; font-size: 15px;">Professional-grade trading journal for quantitative traders and hedge fund analysts</p>
            
            <div class="metrics-grid">
                <div class="metric-card">
                    <div class="metric-label">Track</div>
                    <p style="color: var(--text-primary); margin: 12px 0; font-size: 15px;">Record all trades with entry/exit prices, emotions, and strategy details for comprehensive analysis</p>
                </div>
                <div class="metric-card">
                    <div class="metric-label">Analyze</div>
                    <p style="color: var(--text-primary); margin: 12px 0; font-size: 15px;">View detailed P&L, win rates, and performance metrics with advanced charting capabilities</p>
                </div>
                <div class="metric-card">
                    <div class="metric-label">Improve</div>
                    <p style="color: var(--text-primary); margin: 12px 0; font-size: 15px;">Identify patterns and weak points in your trading to refine your strategy over time</p>
                </div>
            </div>

            <div style="display: flex; gap: 16px; justify-content: center; margin-top: 40px; flex-wrap: wrap;">
                <a href="/register" class="btn btn-primary" style="display: inline-flex; align-items: center; gap: 8px;">
                    <i class="fas fa-rocket"></i> Get Started
                </a>
                <a href="/login" class="btn btn-secondary" style="display: inline-flex; align-items: center; gap: 8px;">
                    <i class="fas fa-sign-in-alt"></i> Sign In
                </a>
            </div>
        </div>
    </div>

    <footer>
        <p>TRADING JOURNAL © 2026</p>
    </footer>
</body>
</html>
