<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Profile - Trading Journal</title>
  <link rel='stylesheet' href='/stylesheets/style.css' />
  <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.min.js"></script>
  <style>
    /* Profile Avatar */
    .avatar-circle {
      width: 120px;
      height: 120px;
      border-radius: 50%;
      border: 3px solid var(--gold);
      display: flex;
      align-items: center;
      justify-content: center;
      background: var(--bg-input);
      font-family: var(--font-mono);
      font-size: 48px;
      color: var(--gold);
      font-weight: 700;
      margin: 0 auto 16px;
    }

    .profile-photo {
      width: 100%;
      height: 100%;
      border-radius: 50%;
      object-fit: cover;
    }

    .photo-input {
      display: none;
    }

    .upload-btn {
      background: var(--gold);
      color: var(--bg);
      border: none;
      padding: 10px 16px;
      border-radius: 8px;
      cursor: pointer;
      font-size: 13px;
      font-weight: 600;
      transition: all 0.2s ease;
      display: block;
      margin: 0 auto;
    }

    .upload-btn:hover {
      transform: translateY(-2px);
      opacity: 0.9;
    }

    .user-info-grid {
      display: grid;
      grid-template-columns: 140px 1fr;
      gap: 32px;
      align-items: start;
    }

    .user-info-form {
      display: grid;
      gap: 16px;
    }

    .info-group {
      display: flex;
      flex-direction: column;
      gap: 6px;
    }

    .info-group label {
      font-size: 12px;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 1px;
      font-weight: 600;
    }

    .info-group input,
    .info-group div {
      background: var(--bg-input);
      border: 1px solid var(--border);
      color: var(--text);
      padding: 10px 12px;
      border-radius: 8px;
      font-size: 14px;
      font-family: var(--font-mono);
    }

    .info-group input:disabled {
      color: var(--muted);
      cursor: not-allowed;
    }

    .info-group input:focus {
      outline: none;
      border-color: var(--border-bright);
    }

    .save-btn {
      background: var(--gold);
      color: var(--bg);
      border: none;
      padding: 8px 16px;
      border-radius: 6px;
      cursor: pointer;
      font-size: 12px;
      font-weight: 700;
      transition: all 0.2s ease;
      align-self: flex-start;
    }

    .save-btn:hover {
      transform: translateY(-2px);
      opacity: 0.9;
    }

    /* Rules Section */
    .rules-list {
      display: grid;
      gap: 12px;
      margin-bottom: 20px;
    }

    .rule-row {
      background: var(--bg-input);
      border: 1px solid var(--border);
      border-left: 3px solid var(--gold);
      padding: 12px;
      border-radius: 8px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      transition: all 0.2s ease;
    }

    .rule-row:hover {
      border-left-color: var(--text);
    }

    .rule-content {
      flex: 1;
    }

    .rule-text {
      color: var(--text);
      font-size: 14px;
      font-weight: 500;
      margin-bottom: 6px;
    }

    .rule-category {
      display: inline-block;
      background: var(--bg-hover);
      color: var(--gold);
      padding: 3px 10px;
      border-radius: 4px;
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .rule-actions {
      display: flex;
      gap: 8px;
    }

    .rule-btn {
      padding: 6px 10px;
      border: 1px solid var(--border);
      background: transparent;
      color: var(--text);
      border-radius: 6px;
      cursor: pointer;
      font-size: 11px;
      font-weight: 600;
      transition: all 0.2s ease;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .rule-btn:hover {
      background: var(--border-bright);
    }

    .rule-btn.active {
      background: var(--green);
      border-color: var(--green);
      color: var(--bg);
    }

    .rule-btn.delete {
      color: var(--red);
    }

    .rule-btn.delete:hover {
      background: var(--red);
      color: white;
    }

    .add-rule-form {
      background: var(--bg-hover);
      padding: 16px;
      border-radius: 12px;
      margin-bottom: 20px;
      border: 1px solid var(--border);
    }

    .form-row {
      display: grid;
      grid-template-columns: 1fr 1fr auto;
      gap: 10px;
    }

    .form-row input,
    .form-row select {
      background: var(--bg-input);
      border: 1px solid var(--border);
      color: var(--text);
      padding: 10px 12px;
      border-radius: 8px;
      font-size: 14px;
      font-family: inherit;
      transition: all 0.2s ease;
    }

    .form-row input:focus,
    .form-row select:focus {
      outline: none;
      border-color: var(--border-bright);
    }

    .form-row button {
      background: var(--gold);
      color: var(--bg);
      border: none;
      padding: 10px 16px;
      border-radius: 8px;
      cursor: pointer;
      font-weight: 700;
      font-size: 12px;
      transition: all 0.2s ease;
      text-transform: uppercase;
      letter-spacing: 1px;
    }

    .form-row button:hover {
      transform: translateY(-2px);
      opacity: 0.9;
    }

    /* Goals Section */
    .goals-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 16px;
      margin-bottom: 20px;
    }

    .goal-card {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 16px;
      transition: all 0.2s ease;
    }

    .goal-card:hover {
      border-color: var(--gold);
      box-shadow: 0 0 0 1px var(--gold);
    }

    .goal-type {
      display: inline-block;
      background: var(--bg-hover);
      color: var(--gold);
      padding: 4px 10px;
      border-radius: 4px;
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      margin-bottom: 10px;
    }

    .goal-target {
      font-size: 24px;
      color: var(--green);
      font-weight: 700;
      font-family: var(--font-mono);
      margin-bottom: 10px;
    }

    .progress-track {
      background: var(--bg-input);
      height: 6px;
      border-radius: 6px;
      overflow: hidden;
      margin-bottom: 8px;
      border: 1px solid var(--border);
    }

    .progress-fill {
      height: 100%;
      background: var(--gold);
      transition: width 0.3s ease;
    }

    .goal-progress-text {
      font-size: 12px;
      color: var(--muted);
      margin-bottom: 10px;
      font-family: var(--font-mono);
    }

    .goal-note {
      font-size: 13px;
      color: var(--muted);
      font-style: italic;
      margin-bottom: 12px;
      border-left: 3px solid var(--border);
      padding-left: 10px;
      line-height: 1.4;
    }

    .goal-status {
      display: inline-block;
      font-size: 11px;
      padding: 4px 10px;
      border-radius: 4px;
      margin-bottom: 12px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .goal-status.active {
      background: var(--green);
      color: var(--bg);
    }

    .goal-status.inactive {
      background: var(--red);
      color: white;
    }

    .goal-actions {
      display: flex;
      gap: 8px;
    }

    .goal-actions button {
      flex: 1;
      padding: 8px;
      border: none;
      border-radius: 6px;
      cursor: pointer;
      font-size: 11px;
      font-weight: 700;
      transition: all 0.2s ease;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .goal-edit-btn {
      background: var(--gold);
      color: var(--bg);
    }

    .goal-edit-btn:hover {
      transform: translateY(-2px);
      opacity: 0.9;
    }

    .goal-delete-btn {
      background: var(--red);
      color: white;
    }

    .goal-delete-btn:hover {
      transform: translateY(-2px);
      opacity: 0.9;
    }

    .add-goal-btn {
      background: var(--gold);
      color: var(--bg);
      border: none;
      padding: 10px 16px;
      border-radius: 8px;
      cursor: pointer;
      font-size: 13px;
      font-weight: 700;
      margin-bottom: 20px;
      transition: all 0.2s ease;
      text-transform: uppercase;
      letter-spacing: 1px;
    }

    .add-goal-btn:hover {
      transform: translateY(-2px);
      opacity: 0.9;
    }

    /* Alert Messages */
    .alert {
      padding: 12px 16px;
      border-radius: 8px;
      margin-bottom: 20px;
      border-left: 3px solid;
      display: none;
      animation: fadeIn 0.3s ease;
    }

    .alert.show {
      display: block;
    }

    .alert-success {
      background: var(--bg-input);
      color: var(--green);
      border-left-color: var(--green);
    }

    .alert-error {
      background: var(--bg-input);
      color: var(--red);
      border-left-color: var(--red);
    }

    /* Modal */
    .modal {
      display: none;
      position: fixed;
      z-index: 1000;
      left: 0;
      top: 0;
      width: 100%;
      height: 100%;
      background: rgba(0, 0, 0, 0.7);
      animation: fadeIn 0.3s ease;
    }

    .modal.show {
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .modal-content {
      background: var(--bg-card);
      padding: 24px;
      border-radius: 12px;
      border: 1px solid var(--border);
      max-width: 480px;
      width: 90%;
      animation: slideUp 0.3s ease;
    }

    .modal-header {
      font-size: 16px;
      color: var(--text);
      margin-bottom: 20px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 2px;
      padding-bottom: 12px;
      border-bottom: 1px solid var(--border);
    }

    .form-group {
      margin-bottom: 16px;
    }

    .form-group label {
      display: block;
      color: var(--muted);
      font-size: 12px;
      margin-bottom: 6px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 1px;
    }

    .form-group input,
    .form-group select,
    .form-group textarea {
      width: 100%;
      background: var(--bg-input);
      border: 1px solid var(--border);
      color: var(--text);
      padding: 10px 12px;
      border-radius: 8px;
      font-size: 14px;
      font-family: inherit;
      transition: all 0.2s ease;
    }

    .form-group input:focus,
    .form-group select:focus,
    .form-group textarea:focus {
      outline: none;
      border-color: var(--border-bright);
    }

    .form-group textarea {
      resize: vertical;
      min-height: 80px;
    }

    .modal-actions {
      display: flex;
      gap: 10px;
      justify-content: flex-end;
      margin-top: 20px;
      padding-top: 16px;
      border-top: 1px solid var(--border);
    }

    .modal-btn {
      padding: 10px 16px;
      border: none;
      border-radius: 6px;
      cursor: pointer;
      font-weight: 700;
      transition: all 0.2s ease;
      font-size: 12px;
      text-transform: uppercase;
      letter-spacing: 1px;
    }

    .modal-btn-primary {
      background: var(--gold);
      color: var(--bg);
    }

    .modal-btn-primary:hover {
      transform: translateY(-2px);
      opacity: 0.9;
    }

    .modal-btn-secondary {
      background: transparent;
      color: var(--text);
      border: 1px solid var(--border);
    }

    .modal-btn-secondary:hover {
      background: var(--border-bright);
    }

    .empty-state {
      text-align: center;
      color: var(--muted);
      padding: 40px 20px;
      background: var(--bg-input);
      border: 1px dashed var(--border);
      border-radius: 8px;
    }

    .empty-state-icon {
      font-size: 40px;
      margin-bottom: 12px;
    }

    .empty-state p {
      margin: 0;
      font-size: 14px;
    }

    @media (max-width: 768px) {
      .user-info-grid {
        grid-template-columns: 1fr;
      }

      .form-row {
        grid-template-columns: 1fr;
      }

      .goal-actions {
        flex-direction: column;
      }
    }
  </style>
</head>
<body>
  <!-- NAVBAR -->
  <nav>
    <div class="brand">
      <div class="brand-dot"></div>
      TRADING JOURNAL
    </div>
    <ul>
      <li><a href="/dashboard">Dashboard</a></li>
      <li><a href="/add-trade">Add Trade</a></li>
      <li><a href="/trades">My Trades</a></li>
      <li><a href="/insights">Insights</a></li>
      <li><a href="/profile" class="active">Profile</a></li>
      <li style="margin-left: auto;">
        <div class="theme-toggle-wrap">
          <span class="theme-label" id="themeLabel">DARK</span>
          <button class="theme-toggle" id="themeToggle" onclick="toggleTheme()" title="Toggle theme" aria-label="Toggle theme">
            <div class="theme-thumb" id="themeThumb"></div>
          </button>
        </div>
      </li>
      <li><a href="/logout">Logout</a></li>
    </ul>
  </nav>

  <main>
    <div class="container">
      <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 32px;">
        <h1 style="font-size: 24px; font-weight: 700; color: var(--text); margin: 0;">Your Profile</h1>
        <a href="/dashboard" class="back-link">← Back to Dashboard</a>
      </div>

      <div id="successAlert" class="alert alert-success"></div>
      <div id="errorAlert" class="alert alert-error"></div>

      <!-- User Information Section -->
      <div class="form-section" style="margin-bottom: 24px;">
        <div class="form-section-title">Personal Information</div>
        
        <div class="user-info-grid">
          <div style="text-align: center;">
            <div class="avatar-circle">
              <img id="photoPreview" class="profile-photo" src="<%= user.profilePhoto || 'https://via.placeholder.com/120/0d0d14/c9a84c?text=' + user.username.charAt(0).toUpperCase() %>" alt="Profile" style="display: none;">
              <span id="avatarInitial">
                <%= user.username.charAt(0).toUpperCase() %>
              </span>
            </div>
            <input type="file" id="photoInput" class="photo-input" accept="image/*">
            <button class="upload-btn" onclick="document.getElementById('photoInput').click()">Upload Photo</button>
          </div>

          <div class="user-info-form">
            <div class="info-group">
              <label>Username</label>
              <div style="display: flex; gap: 10px;">
                <input type="text" id="username" value="<%= user.username %>" placeholder="Enter username" style="flex: 1;">
                <button class="save-btn" onclick="saveUsername()">Save</button>
              </div>
            </div>

            <div class="info-group">
              <label>Email</label>
              <input type="email" value="<%= user.email %>" disabled>
            </div>

            <div class="info-group">
              <label>Member Since</label>
              <input type="text" value="<%= new Date(user._id.getTimestamp()).toLocaleDateString() %>" disabled>
            </div>
          </div>
        </div>
      </div>

      <!-- Trading Rules Section -->
      <div class="form-section" style="margin-bottom: 24px;">
        <div class="form-section-title">Trading Rules</div>
        
        <div class="add-rule-form">
          <div class="form-row">
            <input type="text" id="ruleText" placeholder="Enter your trading rule...">
            <select id="ruleCategory">
              <option value="">Select Category</option>
              <option value="Entry">Entry Strategy</option>
              <option value="Exit">Exit Strategy</option>
              <option value="Risk">Risk Management</option>
              <option value="Psychology">Psychology</option>
              <option value="Other">Other</option>
            </select>
            <button onclick="addRule()">+ Add</button>
          </div>
        </div>

        <div id="rulesContainer" class="rules-list">
          <div class="empty-state">
            <div class="empty-state-icon">📭</div>
            <p>No trading rules yet. Add one to get started!</p>
          </div>
        </div>
      </div>

      <!-- Trading Goals Section -->
      <div class="form-section" style="margin-bottom: 24px;">
        <div class="form-section-title">Trading Goals</div>
        
        <button class="add-goal-btn" onclick="openAddGoalModal()">+ Add New Goal</button>

        <div id="goalsContainer" class="goals-grid">
          <div class="empty-state" style="grid-column: 1 / -1;">
            <div class="empty-state-icon">🚀</div>
            <p>No trading goals yet. Set your first goal to track progress!</p>
          </div>
        </div>
      </div>
    </div>
  </main>

  <!-- Add Goal Modal -->
  <div id="addGoalModal" class="modal">
    <div class="modal-content">
      <div class="modal-header">Create New Trading Goal</div>
      
      <div class="form-group">
        <label>Goal Type</label>
        <select id="goalType">
          <option value="Daily">Daily Goal</option>
          <option value="Monthly">Monthly Goal</option>
          <option value="Yearly">Yearly Goal</option>
        </select>
      </div>

      <div class="form-group">
        <label>Target Profit ($)</label>
        <input type="number" id="goalTargetProfit" placeholder="Enter target profit" step="0.01" min="0">
      </div>

      <div class="form-group">
        <label>Motivation Note</label>
        <textarea id="goalNote" placeholder="Add a motivational note for this goal..."></textarea>
      </div>

      <div class="modal-actions">
        <button class="modal-btn modal-btn-secondary" onclick="closeAddGoalModal()">Cancel</button>
        <button class="modal-btn modal-btn-primary" onclick="saveGoal()">Create Goal</button>
      </div>
    </div>
  </div>

  <!-- Edit Goal Modal -->
  <div id="editGoalModal" class="modal">
    <div class="modal-content">
      <div class="modal-header">Edit Trading Goal</div>
      
      <div class="form-group">
        <label>Target Profit ($)</label>
        <input type="number" id="editGoalTargetProfit" placeholder="Enter target profit" step="0.01" min="0">
      </div>

      <div class="form-group">
        <label>Motivation Note</label>
        <textarea id="editGoalNote" placeholder="Add a motivational note for this goal..."></textarea>
      </div>

      <div class="form-group">
        <label>Status</label>
        <select id="editGoalActive">
          <option value="true">Active</option>
          <option value="false">Inactive</option>
        </select>
      </div>

      <div class="modal-actions">
        <button class="modal-btn modal-btn-secondary" onclick="closeEditGoalModal()">Cancel</button>
        <button class="modal-btn modal-btn-primary" onclick="updateGoal()">Update Goal</button>
      </div>
    </div>
  </div>

  <footer>
    <p>Track every trade, improve every day</p>
  </footer>

  <script>
    let currentEditingGoalId = null;
    let allGoals = [];

    // Initialize page
    document.addEventListener('DOMContentLoaded', () => {
      loadRules();
      loadGoals();
      setupPhotoUpload();
    });

    // Photo Upload
    function setupPhotoUpload() {
      document.getElementById('photoInput').addEventListener('change', async (e) => {
        const file = e.target.files[0];
        if (!file) return;

        const formData = new FormData();
        formData.append('profilePhoto', file);

        try {
          const response = await fetch('/profile/upload-photo', {
            method: 'POST',
            body: formData
          });

          const data = await response.json();
          if (data.success) {
            const photoPreview = document.getElementById('photoPreview');
            photoPreview.src = data.photoPath;
            photoPreview.style.display = 'block';
            document.getElementById('avatarInitial').style.display = 'none';
            showAlert(data.success, 'success');
          } else {
            showAlert(data.error || 'Failed to upload photo', 'error');
          }
        } catch (error) {
          showAlert('Error uploading photo', 'error');
        }
      });
    }

    // Username Update
    async function saveUsername() {
      const username = document.getElementById('username').value.trim();
      
      if (!username || username.length < 3) {
        showAlert('Username must be at least 3 characters', 'error');
        return;
      }

      try {
        const response = await fetch('/profile/update-username', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ username })
        });

        const data = await response.json();
        if (data.success) {
          showAlert(data.success, 'success');
        } else {
          showAlert(data.error || 'Failed to update username', 'error');
        }
      } catch (error) {
        showAlert('Error updating username', 'error');
      }
    }

    // Rules Functions
    async function loadRules() {
      try {
        const response = await fetch('/profile/rules');
        const data = await response.json();
        renderRules(data.rules || []);
      } catch (error) {
        console.error('Error loading rules:', error);
      }
    }

    function renderRules(rules) {
      const container = document.getElementById('rulesContainer');
      
      if (rules.length === 0) {
        container.innerHTML = `
          <div class="empty-state">
            <div class="empty-state-icon">📭</div>
            <p>No trading rules yet. Add one to get started!</p>
          </div>
        `;
        return;
      }

      container.innerHTML = rules.map(rule => `
        <div class="rule-row">
          <div class="rule-content">
            <div class="rule-text">${escapeHtml(rule.text)}</div>
            <div>
              ${rule.category ? `<span class="rule-category">${rule.category}</span>` : ''}
            </div>
          </div>
          <div class="rule-actions">
            <button class="rule-btn ${rule.active ? 'active' : ''}" 
              onclick="toggleRule('${rule._id}', ${!rule.active})">
              ${rule.active ? '✓ Active' : '✗ Inactive'}
            </button>
            <button class="rule-btn delete" onclick="deleteRule('${rule._id}')">Delete</button>
          </div>
        </div>
      `).join('');
    }

    async function addRule() {
      const ruleText = document.getElementById('ruleText').value.trim();
      const category = document.getElementById('ruleCategory').value;

      if (!ruleText || ruleText.length < 5) {
        showAlert('Rule must be at least 5 characters', 'error');
        return;
      }

      try {
        const response = await fetch('/profile/rules/add', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ ruleText, category: category || null })
        });

        const data = await response.json();
        if (data.success) {
          showAlert(data.success, 'success');
          document.getElementById('ruleText').value = '';
          document.getElementById('ruleCategory').value = '';
          loadRules();
        } else {
          showAlert(data.error || 'Failed to add rule', 'error');
        }
      } catch (error) {
        showAlert('Error adding rule', 'error');
      }
    }

    async function toggleRule(ruleId, newActive) {
      try {
        const response = await fetch(`/profile/rules/update/${ruleId}`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ active: newActive })
        });

        const data = await response.json();
        if (data.success) {
          loadRules();
        } else {
          showAlert(data.error || 'Failed to update rule', 'error');
        }
      } catch (error) {
        showAlert('Error updating rule', 'error');
      }
    }

    async function deleteRule(ruleId) {
      if (!confirm('Are you sure you want to delete this rule?')) return;

      try {
        const response = await fetch(`/profile/rules/delete/${ruleId}`, {
          method: 'POST'
        });

        const data = await response.json();
        if (data.success) {
          showAlert(data.success, 'success');
          loadRules();
        } else {
          showAlert(data.error || 'Failed to delete rule', 'error');
        }
      } catch (error) {
        showAlert('Error deleting rule', 'error');
      }
    }

    // Goals Functions
    async function loadGoals() {
      try {
        const response = await fetch('/goals');
        const data = await response.json();
        allGoals = data.goals || [];
        renderGoals(allGoals);
      } catch (error) {
        console.error('Error loading goals:', error);
      }
    }

    function renderGoals(goals) {
      const container = document.getElementById('goalsContainer');
      
      if (goals.length === 0) {
        container.innerHTML = `
          <div class="empty-state" style="grid-column: 1 / -1;">
            <div class="empty-state-icon">🚀</div>
            <p>No trading goals yet. Set your first goal to track progress!</p>
          </div>
        `;
        return;
      }

      container.innerHTML = goals.map(goal => {
        const progressColor = goal.progressPercentage > 80 ? 'var(--green)' : 
                             goal.progressPercentage > 40 ? 'var(--gold)' : 'var(--red)';
        
        return `
          <div class="goal-card">
            <div class="goal-type">${goal.type}</div>
            <div class="goal-target">$${goal.targetProfit.toFixed(2)}</div>
            
            <div class="progress-track">
              <div class="progress-fill" style="width: ${goal.progressPercentage}%; background: ${progressColor};"></div>
            </div>
            
            <div class="goal-progress-text">
              $${goal.currentProgress.toFixed(2)} / $${goal.targetProfit.toFixed(2)} (${goal.progressPercentage}%)
            </div>

            ${goal.note ? `<div class="goal-note">"${escapeHtml(goal.note)}"</div>` : ''}

            <div class="goal-status ${goal.active ? 'active' : 'inactive'}">
              ${goal.active ? '✓ Active' : '✗ Inactive'}
            </div>

            <div class="goal-actions">
              <button class="goal-edit-btn" onclick="openEditGoalModal('${goal._id}')">Edit</button>
              <button class="goal-delete-btn" onclick="deleteGoal('${goal._id}')">Delete</button>
            </div>
          </div>
        `;
      }).join('');
    }

    function openAddGoalModal() {
      document.getElementById('addGoalModal').classList.add('show');
    }

    function closeAddGoalModal() {
      document.getElementById('addGoalModal').classList.remove('show');
      document.getElementById('goalType').value = 'Daily';
      document.getElementById('goalTargetProfit').value = '';
      document.getElementById('goalNote').value = '';
    }

    async function saveGoal() {
      const type = document.getElementById('goalType').value;
      const targetProfit = document.getElementById('goalTargetProfit').value;
      const note = document.getElementById('goalNote').value.trim();

      if (!targetProfit || parseFloat(targetProfit) <= 0) {
        showAlert('Target profit must be greater than 0', 'error');
        return;
      }

      try {
        const response = await fetch('/goals/create', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ type, targetProfit: parseFloat(targetProfit), note })
        });

        const data = await response.json();
        if (data.success) {
          showAlert(data.success, 'success');
          closeAddGoalModal();
          loadGoals();
        } else {
          showAlert(data.error || 'Failed to create goal', 'error');
        }
      } catch (error) {
        showAlert('Error creating goal', 'error');
      }
    }

    function openEditGoalModal(goalId) {
      const goal = allGoals.find(g => g._id === goalId);
      if (!goal) return;

      currentEditingGoalId = goalId;
      document.getElementById('editGoalTargetProfit').value = goal.targetProfit;
      document.getElementById('editGoalNote').value = goal.note || '';
      document.getElementById('editGoalActive').value = goal.active;
      document.getElementById('editGoalModal').classList.add('show');
    }

    function closeEditGoalModal() {
      document.getElementById('editGoalModal').classList.remove('show');
      currentEditingGoalId = null;
    }

    async function updateGoal() {
      if (!currentEditingGoalId) return;

      const targetProfit = document.getElementById('editGoalTargetProfit').value;
      const note = document.getElementById('editGoalNote').value.trim();
      const active = document.getElementById('editGoalActive').value;

      if (!targetProfit || parseFloat(targetProfit) <= 0) {
        showAlert('Target profit must be greater than 0', 'error');
        return;
      }

      try {
        const response = await fetch(`/goals/update/${currentEditingGoalId}`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ targetProfit: parseFloat(targetProfit), note, active })
        });

        const data = await response.json();
        if (data.success) {
          showAlert(data.success, 'success');
          closeEditGoalModal();
          loadGoals();
        } else {
          showAlert(data.error || 'Failed to update goal', 'error');
        }
      } catch (error) {
        showAlert('Error updating goal', 'error');
      }
    }

    async function deleteGoal(goalId) {
      if (!confirm('Are you sure you want to delete this goal?')) return;

      try {
        const response = await fetch(`/goals/delete/${goalId}`, {
          method: 'POST'
        });

        const data = await response.json();
        if (data.success) {
          showAlert(data.success, 'success');
          loadGoals();
        } else {
          showAlert(data.error || 'Failed to delete goal', 'error');
        }
      } catch (error) {
        showAlert('Error deleting goal', 'error');
      }
    }

    // Utility Functions
    function showAlert(message, type) {
      const alert = document.getElementById(type === 'success' ? 'successAlert' : 'errorAlert');
      alert.textContent = message;
      alert.classList.add('show');

      setTimeout(() => {
        alert.classList.remove('show');
      }, 4000);
    }

    function escapeHtml(text) {
      const div = document.createElement('div');
      div.textContent = text;
      return div.innerHTML;
    }

    // Close modals when clicking outside
    window.addEventListener('click', (e) => {
      const addModal = document.getElementById('addGoalModal');
      const editModal = document.getElementById('editGoalModal');
      
      if (e.target === addModal) addModal.classList.remove('show');
      if (e.target === editModal) editModal.classList.remove('show');
    });

    // ===== THEME TOGGLE =====
    function toggleTheme() {
      var isLight = document.body.classList.toggle('light-mode');
      document.getElementById('themeLabel').textContent = isLight ? 'LIGHT' : 'DARK';
      localStorage.setItem('tj-theme', isLight ? 'light' : 'dark');
    }
    
    (function() {
      if (localStorage.getItem('tj-theme') === 'light') {
        document.body.classList.add('light-mode');
        var lbl = document.getElementById('themeLabel');
        if (lbl) lbl.textContent = 'LIGHT';
      }
    })();

    lucide.createIcons();
  </script>
</body>
</html>
