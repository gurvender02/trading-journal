<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add Trade - Trading Journal</title>
    <link rel='stylesheet' href='/stylesheets/style.css' />
    <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.min.js"></script>
    <style>
        /* ══════════════════════════════════
           ADD TRADE — 5-STEP WIZARD
        ══════════════════════════════════ */
        @keyframes stepIn  { from { opacity:0; transform:translateX(18px); } to { opacity:1; transform:translateX(0); } }
        @keyframes stepOut { from { opacity:1; } to { opacity:0; } }
        @keyframes fadeUp  { from { opacity:0; transform:translateY(10px); } to { opacity:1; transform:translateY(0); } }

        .at-wrap {
            max-width: 820px;
            margin: 0 auto;
            padding: 32px 24px 60px;
        }

        /* ── PAGE HEADER ── */
        .at-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 32px;
            animation: fadeUp .4s ease both;
        }
        .at-eyebrow {
            display: flex; align-items: center; gap: 6px;
            font-family: var(--font-mono); font-size: 10px;
            letter-spacing: 3px; color: var(--gold);
            text-transform: uppercase; margin-bottom: 6px;
        }
        .at-header h1 { font-size: 26px; font-weight: 700; letter-spacing: -.02em; }

        /* ── STEP PROGRESS BAR ── */
        .step-nav {
            display: flex;
            align-items: flex-start;
            margin-bottom: 32px;
            animation: fadeUp .4s ease both;
            animation-delay: .05s;
        }
        .step-node { display: flex; flex-direction: column; align-items: center; gap: 7px; cursor: pointer; }
        .step-connector {
            flex: 1; height: 1px; background: var(--border);
            margin: 15px 8px 0; transition: background .3s;
        }
        .step-connector.done { background: var(--green); opacity: .5; }
        .step-dot {
            width: 30px; height: 30px; border-radius: 50%;
            border: 1px solid var(--border-bright);
            background: var(--bg-card);
            display: flex; align-items: center; justify-content: center;
            font-family: var(--font-mono); font-size: 11px; color: var(--dim);
            transition: all .2s;
        }
        .step-dot.active { background: var(--gold); border-color: var(--gold); color: var(--bg); font-weight: 700; }
        .step-dot.done   { background: rgba(0,212,170,.15); border-color: var(--green); color: var(--green); }
        .step-name {
            font-family: var(--font-mono); font-size: 9px;
            letter-spacing: .1em; text-transform: uppercase;
            color: var(--dim); white-space: nowrap;
        }
        .step-name.active { color: var(--gold); }
        .step-name.done   { color: var(--green); opacity: .7; }

        /* ── STEP PANELS ── */
        .step-panel { display: none; animation: stepIn .25s ease both; }
        .step-panel.active { display: block; }

        /* ── PANEL CARD ── */
        .at-card {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 14px;
            padding: 28px 26px;
            margin-bottom: 14px;
        }
        .at-card-hdr {
            display: flex; align-items: center; gap: 12px;
            margin-bottom: 24px;
        }
        .at-icon {
            width: 36px; height: 36px; border-radius: 10px;
            display: flex; align-items: center; justify-content: center;
        }
        .at-icon.gold   { background: rgba(201,168,76,.12); }
        .at-icon.blue   { background: rgba(79,142,247,.12); }
        .at-icon.teal   { background: rgba(0,212,170,.12);  }
        .at-icon.red    { background: rgba(255,69,96,.12);   }
        .at-icon.purple { background: rgba(130,80,220,.12); }
        .at-card-title { font-size: 14px; font-weight: 700; }
        .at-card-sub   { font-size: 11px; color: var(--dim); font-family: var(--font-mono); margin-top: 2px; }

        /* ── SECTION DIVIDER ── */
        .at-sec {
            display: flex; align-items: center; gap: 10px;
            font-family: var(--font-mono); font-size: 9px;
            letter-spacing: .18em; text-transform: uppercase;
            color: var(--dim); margin: 20px 0 14px;
        }
        .at-sec::after { content: ''; flex: 1; height: 1px; background: var(--border); }

        /* ── FIELD ── */
        .at-grid2 { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
        .at-grid3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 14px; }
        .at-grid1 { display: grid; grid-template-columns: 1fr; gap: 14px; }

        .fg { display: flex; flex-direction: column; gap: 7px; }
        .fg label {
            font-family: var(--font-mono); font-size: 9px;
            letter-spacing: .14em; text-transform: uppercase; color: var(--dim);
        }
        .req { color: var(--gold); margin-left: 2px; }

        .fg input,
        .fg select,
        .fg textarea {
            background: var(--bg-input); border: 1px solid var(--border);
            border-radius: 9px; color: var(--text);
            font-family: var(--font-mono); font-size: 13px;
            padding: 11px 14px; width: 100%; outline: none;
            transition: border-color .15s, background .15s;
        }
        .fg input:focus,
        .fg select:focus,
        .fg textarea:focus { border-color: var(--border-bright); background: #111120; }
        .fg input::placeholder,
        .fg textarea::placeholder { color: var(--dim); }
        .fg textarea { resize: vertical; min-height: 80px; line-height: 1.6; font-family: var(--font-ui); font-size: 13px; }
        .fg select {
            cursor: pointer; appearance: none;
            background-image: url("data:image/svg+xml;charset=UTF-8,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='%23444460' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'%3e%3cpolyline points='6 9 12 15 18 9'%3e%3c/polyline%3e%3c/svg%3e");
            background-repeat: no-repeat; background-position: right 12px center; background-size: 16px; padding-right: 36px;
        }

        /* light mode inputs */
        body.light-mode .fg input,
        body.light-mode .fg select,
        body.light-mode .fg textarea { background: #eef0f4; border-color: #dde1ea; color: #1a1a2e; }
        body.light-mode .fg input:focus,
        body.light-mode .fg select:focus,
        body.light-mode .fg textarea:focus { background: #fff; border-color: #c8cdd8; }

        /* ── TRADE TYPE TOGGLE ── */
        .type-toggle { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
        .type-btn {
            padding: 16px; border-radius: 11px;
            border: 1px solid var(--border); background: var(--bg-input);
            color: var(--muted); font-family: var(--font-mono);
            font-size: 12px; font-weight: 500;
            letter-spacing: .06em; text-transform: uppercase;
            cursor: pointer; transition: all .15s; text-align: center;
            display: flex; flex-direction: column; align-items: center; gap: 4px;
        }
        .type-btn-icon { font-size: 18px; }
        .type-btn:hover { border-color: var(--border-bright); color: var(--text); }
        .type-btn.buy-on  { background: rgba(0,212,170,.1);  border-color: var(--green); color: var(--green); }
        .type-btn.sell-on { background: rgba(255,69,96,.1);   border-color: var(--red);   color: var(--red);   }

        /* hidden real select for form submission */
        #tradeType { display: none; }

        /* ── LIVE P/L DISPLAY ── */
        .pl-box {
            background: var(--bg-input); border: 1px solid var(--border);
            border-radius: 10px; padding: 16px 18px;
            display: flex; align-items: center; justify-content: space-between;
            margin-top: 4px;
        }
        body.light-mode .pl-box { background: #eef0f4; border-color: #dde1ea; }
        .pl-lbl { font-family: var(--font-mono); font-size: 9px; letter-spacing: .14em; text-transform: uppercase; color: var(--dim); margin-bottom: 4px; }
        .pl-breakdown { font-family: var(--font-mono); font-size: 10px; color: var(--dim); }
        .pl-val { font-family: var(--font-mono); font-size: 24px; font-weight: 500; color: var(--muted); }
        .pl-val.pos { color: var(--green); }
        .pl-val.neg { color: var(--red);   }

        /* ── QUALITY RATING ── */
        .q-row { display: flex; gap: 8px; }
        .q-btn {
            flex: 1; padding: 9px 4px; border-radius: 7px;
            border: 1px solid var(--border); background: var(--bg-input);
            color: var(--dim); font-family: var(--font-mono);
            font-size: 10px; text-align: center; cursor: pointer;
            transition: all .15s; user-select: none;
        }
        .q-btn:hover { border-color: var(--border-bright); color: var(--muted); }
        .q-btn.on-1 { background: rgba(255,69,96,.1);  border-color: rgba(255,69,96,.4);  color: var(--red);   }
        .q-btn.on-2 { background: rgba(237,137,54,.1); border-color: rgba(237,137,54,.4); color: #ed8936; }
        .q-btn.on-3 { background: rgba(201,168,76,.1); border-color: rgba(201,168,76,.4); color: var(--gold); }
        .q-btn.on-4 { background: rgba(0,212,170,.1);  border-color: rgba(0,212,170,.3);  color: var(--green); }
        .q-btn.on-5 { background: rgba(0,212,170,.15); border-color: var(--green);        color: var(--green); }

        /* hidden selects for quality */
        #entryQuality, #exitQuality { display: none; }

        /* ── EMOTION PILLS ── */
        .emo-pills { display: flex; flex-wrap: wrap; gap: 8px; }
        .emo-pill {
            padding: 7px 15px; border-radius: 20px;
            border: 1px solid var(--border); background: var(--bg-input);
            color: var(--muted); font-family: var(--font-mono); font-size: 11px;
            cursor: pointer; transition: all .15s; user-select: none;
        }
        .emo-pill:hover { border-color: var(--border-bright); color: var(--text); }
        .emo-pill.on-calm      { background: rgba(79,142,247,.12);  border-color: #4f8ef7; color: #4f8ef7; }
        .emo-pill.on-confident { background: rgba(0,212,170,.12);   border-color: var(--green); color: var(--green); }
        .emo-pill.on-excited   { background: rgba(130,80,220,.12);  border-color: #8250dc; color: #8250dc; }
        .emo-pill.on-anxious   { background: rgba(237,137,54,.12);  border-color: #ed8936; color: #ed8936; }
        .emo-pill.on-fearful   { background: rgba(255,69,96,.12);   border-color: var(--red); color: var(--red); }
        .emo-pill.on-fomo      { background: rgba(201,168,76,.12);  border-color: var(--gold); color: var(--gold); }
        .emo-pill.on-neutral   { background: rgba(136,136,170,.12); border-color: var(--muted); color: var(--muted); }
        .emo-pill.on-greed     { background: rgba(255,69,96,.12);   border-color: var(--red); color: var(--red); }

        /* hidden emotionBefore input */
        #emotionBefore { display: none; }

        /* ── DISCIPLINE TOGGLES ── */
        .disc-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
        .disc-item {
            display: flex; align-items: center; gap: 10px;
            padding: 13px 15px; border-radius: 10px;
            border: 1px solid var(--border); background: var(--bg-input);
            cursor: pointer; transition: all .15s; user-select: none;
        }
        .disc-item:hover { border-color: var(--border-bright); }
        .disc-check {
            width: 20px; height: 20px; border-radius: 5px;
            border: 1px solid var(--border-bright); background: var(--bg-card);
            display: flex; align-items: center; justify-content: center;
            font-size: 12px; flex-shrink: 0; transition: all .15s;
        }
        .disc-item.on-good .disc-check { background: var(--green); border-color: var(--green); color: var(--bg); }
        .disc-item.on-good { border-color: rgba(0,212,170,.3); }
        .disc-item.on-bad .disc-check  { background: var(--red);   border-color: var(--red);   color: #fff; }
        .disc-item.on-bad  { border-color: rgba(255,69,96,.3); }
        .disc-lbl { font-size: 12px; color: var(--muted); transition: color .15s; }
        .disc-item.on-good .disc-lbl,
        .disc-item.on-bad  .disc-lbl { color: var(--text); }

        /* real checkboxes hidden */
        #followedPlan, #overTrading, #revengeTrade, #stickedStopLoss { display: none; }

        /* ── MISTAKE TAGS ── */
        .mk-tags { display: flex; flex-wrap: wrap; gap: 8px; }
        .mk-tag {
            padding: 7px 13px; border-radius: 7px;
            border: 1px solid var(--border); background: var(--bg-input);
            color: var(--muted); font-family: var(--font-mono); font-size: 11px;
            cursor: pointer; transition: all .15s; user-select: none;
        }
        .mk-tag:hover { border-color: var(--border-bright); color: var(--text); }
        .mk-tag.on { background: rgba(255,69,96,.1); border-color: rgba(255,69,96,.35); color: var(--red); }

        /* ── TRADE SUMMARY CARD ── */
        .summary-card {
            background: var(--bg-input); border: 1px solid var(--border);
            border-radius: 10px; padding: 16px 18px; margin-bottom: 20px;
        }
        body.light-mode .summary-card { background: #eef0f4; border-color: #dde1ea; }
        .summary-lbl { font-family: var(--font-mono); font-size: 9px; letter-spacing: .14em; text-transform: uppercase; color: var(--dim); margin-bottom: 12px; }
        .summary-row { display: grid; grid-template-columns: repeat(4,1fr); gap: 14px; }
        .sum-item-lbl { font-family: var(--font-mono); font-size: 9px; letter-spacing: .1em; text-transform: uppercase; color: var(--dim); margin-bottom: 4px; }
        .sum-item-val { font-family: var(--font-mono); font-size: 15px; font-weight: 500; color: var(--text); }

        /* ── NAVIGATION BUTTONS ── */
        .step-nav-btns {
            display: flex; gap: 12px; align-items: center; margin-top: 26px;
        }
        .btn-next {
            background: var(--gold); color: var(--bg);
            border: none; border-radius: 9px;
            padding: 12px 30px; font-family: var(--font-ui);
            font-size: 11px; font-weight: 700; letter-spacing: .07em;
            text-transform: uppercase; cursor: pointer;
            transition: opacity .15s, transform .12s;
        }
        .btn-next:hover { opacity: .88; transform: translateY(-1px); }
        .btn-next.green { background: var(--green); }
        .btn-back {
            background: transparent; border: 1px solid var(--border-bright);
            color: var(--muted); border-radius: 9px;
            padding: 12px 22px; font-family: var(--font-ui);
            font-size: 11px; font-weight: 600; cursor: pointer;
            transition: all .15s;
        }
        .btn-back:hover { color: var(--text); border-color: var(--muted); }
        .step-counter { font-family: var(--font-mono); font-size: 10px; color: var(--dim); margin-left: auto; }

        /* ── RESPONSIVE ── */
        @media (max-width: 600px) {
            .at-grid2, .disc-grid { grid-template-columns: 1fr; }
            .at-grid3 { grid-template-columns: 1fr 1fr; }
            .summary-row { grid-template-columns: 1fr 1fr; }
        }
    </style>
</head>
<body>
    <!-- NAVBAR -->
    <nav>
        <div class="brand">
            <div class="brand-dot"></div>
            TRADING JOURNAL
        </div>
        <ul>
            <li><a href="/dashboard">Dashboard</a></li>
            <li><a href="/add-trade" class="active">Add Trade</a></li>
            <li><a href="/trades">My Trades</a></li>
            <li><a href="/insights">Insights</a></li>
            <li><a href="/profile">Profile</a></li>
            <li style="margin-left: auto;">
                <div class="theme-toggle-wrap">
                    <span class="theme-label" id="themeLabel">DARK</span>
                    <button class="theme-toggle" id="themeToggle" onclick="toggleTheme()" title="Toggle theme" aria-label="Toggle theme">
                        <div class="theme-thumb" id="themeThumb"></div>
                    </button>
                </div>
            </li>
            <li><a href="/logout">Logout</a></li>
        </ul>
    </nav>

    <div class="at-wrap">

        <% if (error) { %>
        <div class="alert alert-danger"><strong>Error:</strong> <%= error %></div>
        <% } %>
        <% if (success) { %>
        <div class="alert alert-success"><strong>Success:</strong> <%= success %></div>
        <% } %>

        <!-- PAGE HEADER -->
        <div class="at-header">
            <div>
                <div class="at-eyebrow">
                    <i data-lucide="plus-circle" style="width:12px;height:12px;"></i>
                    New Entry
                </div>
                <h1>Add Trade</h1>
            </div>
            <a href="/dashboard" class="btn btn-ghost" style="margin-top:8px;">← Dashboard</a>
        </div>

        <!-- STEP PROGRESS -->
        <div class="step-nav" id="stepNav">
            <div class="step-node" onclick="tryGoStep(1)">
                <div class="step-dot active" id="sd1">1</div>
                <div class="step-name active" id="sn1">Basics</div>
            </div>
            <div class="step-connector" id="sc12"></div>
            <div class="step-node" onclick="tryGoStep(2)">
                <div class="step-dot" id="sd2">2</div>
                <div class="step-name" id="sn2">Entry & Exit</div>
            </div>
            <div class="step-connector" id="sc23"></div>
            <div class="step-node" onclick="tryGoStep(3)">
                <div class="step-dot" id="sd3">3</div>
                <div class="step-name" id="sn3">Strategy</div>
            </div>
            <div class="step-connector" id="sc34"></div>
            <div class="step-node" onclick="tryGoStep(4)">
                <div class="step-dot" id="sd4">4</div>
                <div class="step-name" id="sn4">Mind</div>
            </div>
            <div class="step-connector" id="sc45"></div>
            <div class="step-node" onclick="tryGoStep(5)">
                <div class="step-dot" id="sd5">5</div>
                <div class="step-name" id="sn5">Review</div>
            </div>
        </div>

        <!-- THE REAL FORM — wraps ALL steps -->
        <form method="POST" id="tradeForm">

            <!-- ══ STEP 1 — BASICS ══ -->
            <div class="step-panel active" id="sp1">
                <div class="at-card">
                    <div class="at-card-hdr">
                        <div class="at-icon gold">
                            <i data-lucide="clipboard-list" style="width:18px;height:18px;color:#c9a84c;"></i>
                        </div>
                        <div>
                            <div class="at-card-title">Trade basics</div>
                            <div class="at-card-sub">Stock, type & timestamp</div>
                        </div>
                    </div>

                    <div class="at-grid1" style="margin-bottom:18px;">
                        <div class="fg">
                            <label>Stock name<span class="req">*</span></label>
                            <input type="text" id="stockName" name="stockName" placeholder="e.g., AAPL, NIFTY50, GOOGL" required oninput="updateSummary()">
                        </div>
                    </div>

                    <div class="at-sec">Trade type</div>
                    <!-- Visual toggle -->
                    <div class="type-toggle" style="margin-bottom:18px;">
                        <div class="type-btn" id="btnBuy" onclick="setType('Buy')">
                            <span class="type-btn-icon">↑</span>
                            Buy / Long
                        </div>
                        <div class="type-btn" id="btnSell" onclick="setType('Sell')">
                            <span class="type-btn-icon">↓</span>
                            Sell / Short
                        </div>
                    </div>
                    <!-- Real select (hidden, submitted with form) -->
                    <select id="tradeType" name="tradeType" required>
                        <option value="">-- Select --</option>
                        <option value="Buy">Buy</option>
                        <option value="Sell">Sell</option>
                    </select>

                    <div class="at-grid2">
                        <div class="fg">
                            <label>Date & time<span class="req">*</span></label>
                            <input type="datetime-local" id="tradeDateTime" name="tradeDateTime" required>
                        </div>
                        <div class="fg">
                            <label>Quantity<span class="req">*</span></label>
                            <input type="number" id="quantity" name="quantity" placeholder="1" step="1" min="1" required oninput="calcPL()">
                        </div>
                    </div>
                </div>

                <div class="step-nav-btns">
                    <button type="button" class="btn-next" onclick="goStep(2)">Next: Entry & Exit →</button>
                    <span class="step-counter">Step 1 of 5</span>
                </div>
            </div>

            <!-- ══ STEP 2 — ENTRY & EXIT ══ -->
            <div class="step-panel" id="sp2">
                <div class="at-card">
                    <div class="at-card-hdr">
                        <div class="at-icon blue">
                            <i data-lucide="trending-up" style="width:18px;height:18px;color:#4f8ef7;"></i>
                        </div>
                        <div>
                            <div class="at-card-title">Entry & exit</div>
                            <div class="at-card-sub">Prices, stop loss & live P/L</div>
                        </div>
                    </div>

                    <div class="at-grid2" style="margin-bottom:16px;">
                        <div class="fg">
                            <label>Entry price $<span class="req">*</span></label>
                            <input type="number" id="entryPrice" name="entryPrice" placeholder="0.00" step="any" min="0.01" required oninput="calcPL()">
                        </div>
                        <div class="fg">
                            <label>Exit price $<span class="req">*</span></label>
                            <input type="number" id="exitPrice" name="exitPrice" placeholder="0.00" step="any" min="0.01" required oninput="calcPL()">
                        </div>
                        <div class="fg">
                            <label>Stop loss $</label>
                            <input type="number" id="stopLoss" name="stopLoss" placeholder="0.00" step="any" min="0">
                        </div>
                        <div class="fg">
                            <label>Risk %</label>
                            <input type="number" id="riskPercent" name="riskPercent" placeholder="0.00" step="any" min="0">
                        </div>
                    </div>

                    <!-- Live P/L -->
                    <div class="pl-box">
                        <div>
                            <div class="pl-lbl">Estimated P/L</div>
                            <div class="pl-breakdown" id="plBreakdown">Enter prices above to calculate</div>
                        </div>
                        <div class="pl-val" id="plVal">—</div>
                    </div>
                </div>

                <div class="step-nav-btns">
                    <button type="button" class="btn-back" onclick="goStep(1)">← Back</button>
                    <button type="button" class="btn-next" onclick="goStep(3)">Next: Strategy →</button>
                    <span class="step-counter">Step 2 of 5</span>
                </div>
            </div>

            <!-- ══ STEP 3 — STRATEGY ══ -->
            <div class="step-panel" id="sp3">
                <div class="at-card">
                    <div class="at-card-hdr">
                        <div class="at-icon teal">
                            <i data-lucide="target" style="width:18px;height:18px;color:#00d4aa;"></i>
                        </div>
                        <div>
                            <div class="at-card-title">Strategy & market context</div>
                            <div class="at-card-sub">How and why you took this trade</div>
                        </div>
                    </div>

                    <div class="at-grid2" style="margin-bottom:16px;">
                        <div class="fg">
                            <label>Strategy used<span class="req">*</span></label>
                            <select id="strategy" name="strategy" required>
                                <option value="">-- Select a strategy --</option>
                                <option value="Momentum">Momentum</option>
                                <option value="Mean Reversion">Mean Reversion</option>
                                <option value="Breakout">Breakout</option>
                                <option value="Trend Following">Trend Following</option>
                                <option value="Support/Resistance">Support/Resistance</option>
                                <option value="Moving Averages">Moving Averages</option>
                                <option value="RSI Oversold/Overbought">RSI Oversold/Overbought</option>
                                <option value="MACD Crossover">MACD Crossover</option>
                                <option value="Bollinger Bands">Bollinger Bands</option>
                                <option value="Swing Trading">Swing Trading</option>
                                <option value="Day Trading">Day Trading</option>
                                <option value="Scalping">Scalping</option>
                                <option value="Options Strategy">Options Strategy</option>
                                <option value="Other">Other</option>
                            </select>
                        </div>
                        <div class="fg">
                            <label>Setup type</label>
                            <input type="text" id="setupType" name="setupType" placeholder="e.g., Morning Gap, Range Break">
                        </div>
                        <div class="fg">
                            <label>Market trend</label>
                            <select id="marketTrend" name="marketTrend">
                                <option value="">-- Select --</option>
                                <option value="Up">Up trend</option>
                                <option value="Down">Down trend</option>
                                <option value="Sideways">Sideways</option>
                            </select>
                        </div>
                        <div class="fg">
                            <label>Volatility level</label>
                            <select id="volatility" name="volatility">
                                <option value="">-- Select --</option>
                                <option value="Low">Low</option>
                                <option value="Medium">Medium</option>
                                <option value="High">High</option>
                            </select>
                        </div>
                    </div>

                    <div class="at-sec">Execution quality</div>
                    <div class="at-grid2">
                        <div class="fg">
                            <label>Entry quality</label>
                            <div class="q-row" id="eqRow">
                                <div class="q-btn" onclick="setQ('eq',1,this)">1<br><span style="font-size:8px;opacity:.7;">Poor</span></div>
                                <div class="q-btn" onclick="setQ('eq',2,this)">2</div>
                                <div class="q-btn" onclick="setQ('eq',3,this)">3<br><span style="font-size:8px;opacity:.7;">OK</span></div>
                                <div class="q-btn" onclick="setQ('eq',4,this)">4</div>
                                <div class="q-btn" onclick="setQ('eq',5,this)">5<br><span style="font-size:8px;opacity:.7;">Best</span></div>
                            </div>
                            <!-- hidden selects for form POST -->
                            <select id="entryQuality" name="entryQuality">
                                <option value="">-- Select --</option>
                                <option value="Planned">Planned</option>
                                <option value="Early">Early</option>
                                <option value="Late">Late</option>
                                <option value="Emotional">Emotional</option>
                            </select>
                        </div>
                        <div class="fg">
                            <label>Exit quality</label>
                            <div class="q-row" id="xqRow">
                                <div class="q-btn" onclick="setQ('xq',1,this)">1<br><span style="font-size:8px;opacity:.7;">Poor</span></div>
                                <div class="q-btn" onclick="setQ('xq',2,this)">2</div>
                                <div class="q-btn" onclick="setQ('xq',3,this)">3<br><span style="font-size:8px;opacity:.7;">OK</span></div>
                                <div class="q-btn" onclick="setQ('xq',4,this)">4</div>
                                <div class="q-btn" onclick="setQ('xq',5,this)">5<br><span style="font-size:8px;opacity:.7;">Best</span></div>
                            </div>
                            <select id="exitQuality" name="exitQuality">
                                <option value="">-- Select --</option>
                                <option value="Planned">Planned</option>
                                <option value="Early">Early</option>
                                <option value="Late">Late</option>
                                <option value="Emotional">Emotional</option>
                            </select>
                        </div>
                    </div>
                </div>

                <div class="step-nav-btns">
                    <button type="button" class="btn-back" onclick="goStep(2)">← Back</button>
                    <button type="button" class="btn-next" onclick="goStep(4)">Next: Mind →</button>
                    <span class="step-counter">Step 3 of 5</span>
                </div>
            </div>

            <!-- ══ STEP 4 — MIND ══ -->
            <div class="step-panel" id="sp4">
                <div class="at-card">
                    <div class="at-card-hdr">
                        <div class="at-icon red">
                            <i data-lucide="brain" style="width:18px;height:18px;color:#ff4560;"></i>
                        </div>
                        <div>
                            <div class="at-card-title">Emotional state & discipline</div>
                            <div class="at-card-sub">The psychology behind the trade</div>
                        </div>
                    </div>

                    <div class="at-sec">Emotion before trade</div>
                    <!-- Visual pill selector — writes to hidden input -->
                    <div class="emo-pills" style="margin-bottom:18px;" id="emoPills">
                        <div class="emo-pill" data-emo="Calm"      onclick="toggleEmo(this)">Calm</div>
                        <div class="emo-pill" data-emo="Confident" onclick="toggleEmo(this)">Confident</div>
                        <div class="emo-pill" data-emo="Excited"   onclick="toggleEmo(this)">Excited</div>
                        <div class="emo-pill" data-emo="Anxious"   onclick="toggleEmo(this)">Anxious</div>
                        <div class="emo-pill" data-emo="Fearful"   onclick="toggleEmo(this)">Fearful</div>
                        <div class="emo-pill" data-emo="FOMO"      onclick="toggleEmo(this)">FOMO</div>
                        <div class="emo-pill" data-emo="Neutral"   onclick="toggleEmo(this)">Neutral</div>
                        <div class="emo-pill" data-emo="Greed"     onclick="toggleEmo(this)">Greed</div>
                    </div>
                    <input type="hidden" id="emotionBefore" name="emotionBefore">

                    <div class="at-grid2" style="margin-bottom:20px;">
                        <div class="fg">
                            <label>Emotion during trade</label>
                            <select id="emotion" name="emotion">
                                <option value="">-- Select --</option>
                                <option value="Calm">Calm</option>
                                <option value="Fear">Fear</option>
                                <option value="Greed">Greed</option>
                                <option value="FOMO">FOMO</option>
                                <option value="Confident">Confident</option>
                                <option value="Excited">Excited</option>
                                <option value="Anxious">Anxious</option>
                                <option value="Neutral">Neutral</option>
                            </select>
                        </div>
                        <div class="fg">
                            <label>Emotion after trade</label>
                            <input type="text" id="emotionAfter" name="emotionAfter" placeholder="e.g., Satisfied, Frustrated">
                        </div>
                    </div>

                    <div class="at-sec">Trading discipline</div>
                    <div class="disc-grid" style="margin-bottom:20px;">
                        <div class="disc-item on-good" id="di-plan" onclick="toggleDisc('di-plan','followedPlan','good')">
                            <div class="disc-check">✓</div>
                            <div class="disc-lbl">Followed trading plan</div>
                        </div>
                        <div class="disc-item" id="di-over" onclick="toggleDisc('di-over','overTrading','bad')">
                            <div class="disc-check"></div>
                            <div class="disc-lbl">Over traded today</div>
                        </div>
                        <div class="disc-item" id="di-revenge" onclick="toggleDisc('di-revenge','revengeTrade','bad')">
                            <div class="disc-check"></div>
                            <div class="disc-lbl">Took revenge trades</div>
                        </div>
                        <div class="disc-item on-good" id="di-stop" onclick="toggleDisc('di-stop','stickedStopLoss','good')">
                            <div class="disc-check">✓</div>
                            <div class="disc-lbl">Stuck to stop loss</div>
                        </div>
                    </div>
                    <!-- Real checkboxes (hidden, form-submitted) -->
                    <input type="checkbox" id="followedPlan"    name="followedPlan"    checked>
                    <input type="checkbox" id="overTrading"     name="overTrading">
                    <input type="checkbox" id="revengeTrade"    name="revengeTrade">
                    <input type="checkbox" id="stickedStopLoss" name="stickedStopLoss" checked>
                </div>

                <div class="step-nav-btns">
                    <button type="button" class="btn-back" onclick="goStep(3)">← Back</button>
                    <button type="button" class="btn-next" onclick="goStep(5)">Next: Review →</button>
                    <span class="step-counter">Step 4 of 5</span>
                </div>
            </div>

            <!-- ══ STEP 5 — REVIEW & NOTES ══ -->
            <div class="step-panel" id="sp5">
                <div class="at-card">
                    <div class="at-card-hdr">
                        <div class="at-icon purple">
                            <i data-lucide="book-open" style="width:18px;height:18px;color:#8250dc;"></i>
                        </div>
                        <div>
                            <div class="at-card-title">Review & learning</div>
                            <div class="at-card-sub">Reflect to grow faster</div>
                        </div>
                    </div>

                    <div class="at-grid2" style="margin-bottom:16px;">
                        <div class="fg">
                            <label>Key learning from this trade</label>
                            <textarea id="learningNote" name="learningNote" placeholder="What did you learn?" rows="3"></textarea>
                        </div>
                        <div class="fg">
                            <label>Rule for next time</label>
                            <textarea id="nextRule" name="nextRule" placeholder="What will you do differently?" rows="3"></textarea>
                        </div>
                    </div>
                    <div class="fg" style="margin-bottom:22px;">
                        <label>Additional notes</label>
                        <textarea id="notes" name="notes" placeholder="Any other observations..." rows="3"></textarea>
                    </div>

                    <!-- Trade summary before submitting -->
                    <div class="at-sec">Trade summary</div>
                    <div class="summary-card">
                        <div class="summary-row">
                            <div>
                                <div class="sum-item-lbl">Stock</div>
                                <div class="sum-item-val" id="sumStock">—</div>
                            </div>
                            <div>
                                <div class="sum-item-lbl">Type</div>
                                <div class="sum-item-val" id="sumType">—</div>
                            </div>
                            <div>
                                <div class="sum-item-lbl">Strategy</div>
                                <div class="sum-item-val" id="sumStrat">—</div>
                            </div>
                            <div>
                                <div class="sum-item-lbl">Est. P/L</div>
                                <div class="sum-item-val" id="sumPL">—</div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="step-nav-btns">
                    <button type="button" class="btn-back" onclick="goStep(4)">← Back</button>
                    <button type="submit" class="btn-next green">Save Trade Record</button>
                    <a href="/dashboard" class="btn-back" style="text-decoration:none;display:flex;align-items:center;">Cancel</a>
                    <span class="step-counter">Step 5 of 5</span>
                </div>
            </div>

        </form><!-- /tradeForm -->
    </div><!-- /at-wrap -->

    <footer>
        <p>Track every trade, improve every day</p>
    </footer>

    <script>
        // ── STATE ────────────────────────────────────
        let currentStep = 1;
        const TOTAL = 5;

        // ── STEP NAVIGATION ─────────────────────────
        function goStep(n) {
            document.getElementById('sp' + currentStep).classList.remove('active');
            currentStep = n;
            document.getElementById('sp' + n).classList.add('active');
            updateStepNav();
            if (n === 5) updateSummary();
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        function tryGoStep(n) {
            if (n <= currentStep) goStep(n);
        }

        function updateStepNav() {
            for (let i = 1; i <= TOTAL; i++) {
                const dot  = document.getElementById('sd' + i);
                const name = document.getElementById('sn' + i);
                dot.className  = 'step-dot '  + (i < currentStep ? 'done' : i === currentStep ? 'active' : '');
                name.className = 'step-name ' + (i < currentStep ? 'done' : i === currentStep ? 'active' : '');
                dot.textContent = i < currentStep ? '✓' : String(i);
                if (i < TOTAL) {
                    const conn = document.getElementById('sc' + i + (i+1));
                    if (conn) conn.className = 'step-connector ' + (i < currentStep ? 'done' : '');
                }
            }
        }

        // ── TRADE TYPE TOGGLE ────────────────────────
        function setType(t) {
            document.getElementById('tradeType').value = t;
            document.getElementById('btnBuy').className  = 'type-btn' + (t === 'Buy'  ? ' buy-on'  : '');
            document.getElementById('btnSell').className = 'type-btn' + (t === 'Sell' ? ' sell-on' : '');
            calcPL();
            updateSummary();
        }

        // ── LIVE P/L ─────────────────────────────────
        function calcPL() {
            const entry = parseFloat(document.getElementById('entryPrice').value) || 0;
            const exit  = parseFloat(document.getElementById('exitPrice').value)  || 0;
            const qty   = parseFloat(document.getElementById('quantity').value)   || 1;
            const type  = document.getElementById('tradeType').value;
            const el    = document.getElementById('plVal');
            const br    = document.getElementById('plBreakdown');

            if (!entry || !exit) {
                el.textContent = '—'; el.className = 'pl-val';
                br.textContent = 'Enter prices above to calculate';
                updateSummary(); return;
            }
            const pl = type === 'Sell' ? (entry - exit) * qty : (exit - entry) * qty;
            el.textContent = (pl >= 0 ? '+' : '') + '$' + pl.toFixed(2);
            el.className   = 'pl-val ' + (pl > 0 ? 'pos' : pl < 0 ? 'neg' : '');
            br.textContent = qty + ' × ($' + exit.toFixed(2) + ' − $' + entry.toFixed(2) + ')';
            updateSummary();
        }

        // ── SUMMARY ──────────────────────────────────
        function updateSummary() {
            const stock = document.getElementById('stockName').value || '—';
            const type  = document.getElementById('tradeType').value || '—';
            const strat = document.getElementById('strategy').value  || '—';
            const plEl  = document.getElementById('plVal');

            document.getElementById('sumStock').textContent = stock.toUpperCase();
            const typeEl = document.getElementById('sumType');
            typeEl.textContent = type;
            typeEl.style.color = type === 'Buy' ? 'var(--green)' : type === 'Sell' ? 'var(--red)' : 'var(--muted)';
            document.getElementById('sumStrat').textContent = strat;

            const sumPL = document.getElementById('sumPL');
            if (plEl) {
                sumPL.textContent = plEl.textContent;
                sumPL.style.color = plEl.classList.contains('pos') ? 'var(--green)'
                    : plEl.classList.contains('neg') ? 'var(--red)' : 'var(--muted)';
            }
        }

        // ── QUALITY RATING ───────────────────────────
        const qLabels = { eq: ['Planned','Early','Late','Emotional','Planned'], xq: ['Planned','Early','Late','Emotional','Planned'] };
        const qMap    = { eq: 'entryQuality', xq: 'exitQuality' };
        const qValMap = ['','Planned','Early','Late','Emotional','Planned'];

        function setQ(type, val, el) {
            const rowId = type === 'eq' ? 'eqRow' : 'xqRow';
            document.getElementById(rowId).querySelectorAll('.q-btn').forEach(b => b.className = 'q-btn');
            el.className = 'q-btn on-' + val;
            // map rating 1-5 to quality labels for the hidden select
            const qualMap = { 1:'Emotional', 2:'Late', 3:'Planned', 4:'Early', 5:'Planned' };
            document.getElementById(qMap[type]).value = qualMap[val] || 'Planned';
        }

        // ── EMOTION PILLS ────────────────────────────
        const emoClassMap = {
            'Calm':'calm','Confident':'confident','Excited':'excited',
            'Anxious':'anxious','Fearful':'fearful','FOMO':'fomo',
            'Neutral':'neutral','Greed':'greed'
        };
        function toggleEmo(el) {
            const emo = el.getAttribute('data-emo');
            const cls = 'on-' + emoClassMap[emo];
            const isOn = el.classList.contains(cls);
            document.getElementById('emoPills').querySelectorAll('.emo-pill').forEach(p => {
                Object.values(emoClassMap).forEach(c => p.classList.remove('on-' + c));
            });
            if (!isOn) { el.classList.add(cls); document.getElementById('emotionBefore').value = emo; }
            else { document.getElementById('emotionBefore').value = ''; }
        }

        // ── DISCIPLINE TOGGLES ───────────────────────
        function toggleDisc(itemId, checkId, type) {
            const item  = document.getElementById(itemId);
            const check = document.getElementById(checkId);
            const cls   = type === 'good' ? 'on-good' : 'on-bad';
            const isOn  = item.classList.contains(cls);
            item.classList.toggle(cls, !isOn);
            const chkEl = item.querySelector('.disc-check');
            chkEl.textContent = !isOn ? (type === 'good' ? '✓' : '✗') : '';
            check.checked = !isOn;
        }

        // ── THEME ─────────────────────────────────────
        function toggleTheme() {
            const light = document.body.classList.toggle('light-mode');
            document.getElementById('themeLabel').textContent = light ? 'LIGHT' : 'DARK';
            localStorage.setItem('tj-theme', light ? 'light' : 'dark');
        }
        (function() {
            if (localStorage.getItem('tj-theme') === 'light') {
                document.body.classList.add('light-mode');
                var lbl = document.getElementById('themeLabel');
                if (lbl) lbl.textContent = 'LIGHT';
            }
        })();

        // ── BOOT ──────────────────────────────────────
        document.addEventListener('DOMContentLoaded', () => {
            lucide.createIcons();
            // Set default datetime to now
            const now = new Date();
            now.setMinutes(now.getMinutes() - now.getTimezoneOffset());
            document.getElementById('tradeDateTime').value = now.toISOString().slice(0, 16);
            updateStepNav();
        });
    </script>
</body>
</html>
